# ─── Saint Mary School - Vercel Environment Variables ───
# Copy this file to .env and fill in the values
# Then add these in Vercel Dashboard > Settings > Environment Variables

# PostgreSQL Database URL (required)
# Get a FREE database from: https://neon.tech or https://vercel.com/dashboard/stores
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Admin Credentials (required)
ADMIN_EMAIL="admin@saintmaryschool.com"
